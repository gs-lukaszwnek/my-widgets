{
  "version": "1.1.0",
  "title": "Star Wars Browser (Angular)",
  "description": "Search the Star Wars universe by character name and see height, mass, and birth year — powered by SWAPI.",
  "category": "My Widgets",
  "imageSrc": "thumbnail.png",
  "source": {
    "path": "dist",
    "entry": "index.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "title",
        "type": "text",
        "label": "Heading",
        "defaultValue": "Star Wars Browser",
        "rules": {
          "required": true
        }
      },
      {
        "name": "defaultQuery",
        "type": "text",
        "label": "Default search query",
        "defaultValue": "sky"
      }
    ]
  },
  "defaultConfig": {
    "title": "Star Wars Browser",
    "defaultQuery": "sky"
  }
}
