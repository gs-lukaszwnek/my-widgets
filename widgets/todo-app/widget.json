{
  "version": "1.0.0",
  "title": "Todo App",
  "description": "Create, view, and delete todos stored in Supabase. Styled with Adobe Spectrum 2.",
  "category": "Productivity",
  "imageSrc": "thumbnail.png",
  "source": {
    "path": "dist",
    "entry": "index.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "title",
        "type": "text",
        "label": "Heading",
        "defaultValue": "My todos",
        "rules": {
          "required": true
        }
      },
      {
        "name": "placeholder",
        "type": "text",
        "label": "Input placeholder",
        "defaultValue": "What needs doing?"
      }
    ]
  },
  "defaultConfig": {
    "title": "My todos",
    "placeholder": "What needs doing?"
  }
}
