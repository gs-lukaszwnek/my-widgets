{
  "version": "1.0.0",
  "title": "Weather Widget",
  "description": "Shows the current weather based on the user's geolocation. Powered by Open-Meteo.",
  "category": "Utilities",
  "imageSrc": "thumbnail.png",
  "source": {
    "path": "dist",
    "entry": "index.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "temperatureUnit",
        "type": "text",
        "label": "Temperature unit",
        "defaultValue": "celsius",
        "description": "Use 'celsius' or 'fahrenheit'."
      }
    ]
  },
  "defaultConfig": {
    "temperatureUnit": "celsius"
  }
}
