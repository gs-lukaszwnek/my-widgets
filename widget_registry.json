{
  "widgets": [
    {
      "containers": [
        "Full width"
      ],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": true,
        "movable": true
      },
      "version": "1.0.0",
      "title": "Test React",
      "description": "A widget built with React and the Widget SDK.",
      "category": "Demo",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Title",
            "defaultValue": "Test React",
            "rules": {
              "required": true
            }
          },
          {
            "name": "description",
            "type": "text",
            "label": "Description",
            "defaultValue": "A widget built with React and the Widget SDK."
          }
        ]
      },
      "defaultConfig": {
        "title": "Test React",
        "description": "A widget built with React and the Widget SDK."
      },
      "type": "test-react",
      "source": {
        "path": "widgets/test-react/dist",
        "entry": "index.html"
      },
      "imageSrc": "widgets/test-react/thumbnail.png"
    },
    {
      "containers": [
        "Full width"
      ],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": true,
        "movable": true
      },
      "version": "1.0.0",
      "title": "Todo App",
      "description": "Create, view, and delete todos stored in Supabase. Styled with Adobe Spectrum 2.",
      "category": "Productivity",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Heading",
            "defaultValue": "My todos",
            "rules": {
              "required": true
            }
          },
          {
            "name": "placeholder",
            "type": "text",
            "label": "Input placeholder",
            "defaultValue": "What needs doing?"
          }
        ]
      },
      "defaultConfig": {
        "title": "My todos",
        "placeholder": "What needs doing?"
      },
      "type": "todo-app",
      "source": {
        "path": "widgets/todo-app/dist",
        "entry": "index.html"
      },
      "imageSrc": "widgets/todo-app/thumbnail.png"
    }
  ]
}
