{
  "widgets": [
    {
      "type": "supabase-todos",
      "title": "Supabase Todos",
      "version": "1.0.0",
      "category": "Productivity",
      "imageSrc": "widgets/supabase-todos/thumbnail.png",
      "widgetsLibrary": true,
      "containers": [
        "Full width"
      ],
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "source": {
        "path": "widgets/supabase-todos/dist",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "heading",
            "type": "text",
            "label": "Heading",
            "defaultValue": "My Todos",
            "rules": {
              "required": true
            }
          },
          {
            "name": "emptyStateText",
            "type": "text",
            "label": "Empty state message",
            "defaultValue": "No todos yet \u2014 add your first one below."
          },
          {
            "name": "pageSize",
            "type": "number",
            "label": "Max items to display",
            "defaultValue": 20,
            "rules": {
              "required": true
            }
          },
          {
            "name": "theme",
            "type": "select",
            "label": "Spectrum theme",
            "defaultValue": "light",
            "options": [
              { "label": "Light", "value": "light" },
              { "label": "Dark", "value": "dark" }
            ]
          }
        ]
      },
      "defaultConfig": {
        "heading": "My Todos",
        "emptyStateText": "No todos yet \u2014 add your first one below.",
        "pageSize": 20,
        "theme": "light"
      }
    }
  ]
}
