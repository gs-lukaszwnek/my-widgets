{
  "widgets": [
    {
      "title": "Card Grid",
      "description": "A configurable card grid widget demonstrating dynamic layout and styling options",
      "version": "1.0.0",
      "category": "Demo",
      "type": "card_grid",
      "imageName": "banner",
      "content": {
        "endpoint": "./widgets/card_grid/content.html",
        "method": "GET",
        "requiresAuthentication": false,
        "cacheStrategy": "no-cache"
      },
      "configuration": {
        "properties": {
          "test": 1
        }
      },
      "defaultConfig": {
        "cards_per_row": 3,
        "card_background": "#ffffff",
        "card_text_color": "#1f2937",
        "accent_color": "#3b82f6",
        "title_size": "medium",
        "card_style": "shadow",
        "show_icons": "yes"
      },
      "containers": [
        "Full width"
      ],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      }
    },
