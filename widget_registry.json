{
  "widgets": [
    {
      "type": "todo-app",
      "title": "Todo App",
      "version": "1.0.0",
      "category": "Productivity",
      "imageSrc": "widgets/todo-app/thumbnail.png",
      "widgetsLibrary": true,
      "containers": [
        "Full width"
      ],
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "source": {
        "path": "widgets/todo-app/dist",
        "entry": "index.html"
      },
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Title",
            "defaultValue": "My Todos",
            "rules": {
              "required": true,
              "maxLength": 60
            }
          },
          {
            "name": "placeholder",
            "type": "text",
            "label": "Input placeholder",
            "defaultValue": "What needs doing?",
            "rules": {
              "maxLength": 80
            }
          },
          {
            "name": "theme",
            "type": "select",
            "label": "Theme",
            "defaultValue": "light",
            "options": [
              { "label": "Light", "value": "light" },
              { "label": "Dark", "value": "dark" }
            ]
          }
        ]
      },
      "defaultConfig": {
        "title": "My Todos",
        "placeholder": "What needs doing?",
        "theme": "light"
      }
    }
  ]
}
