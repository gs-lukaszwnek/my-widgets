{
  "widgets": [
    {
      "containers": [
        "Full width"
      ],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": true,
        "movable": true
      },
      "version": "1.0.0",
      "title": "Todo App",
      "description": "Create, view, and delete todos, stored in Supabase. UI built with Adobe Spectrum Web Components.",
      "category": "Productivity",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Heading",
            "defaultValue": "My Todos",
            "rules": {
              "required": true,
              "maxLength": 80
            }
          }
        ]
      },
      "defaultConfig": {
        "title": "My Todos"
      },
      "type": "todo-app",
      "source": {
        "path": "widgets/todo-app/dist",
        "entry": "index.html"
      },
      "imageSrc": "widgets/todo-app/thumbnail.png"
    }
  ]
}
